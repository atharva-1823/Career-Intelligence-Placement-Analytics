import numpy as np
import pandas as pd


jobs_df = pd.read_csv("data/jobs.csv")


skills_df=pd.read_csv("data/skills_combined.csv")


jobs_df.shape


skills_df.shape


jobs_df = jobs_df.drop_duplicates()


jobs_df["job_id"].nunique()


jobs_df[jobs_df.duplicated(subset=["job_id"], keep=False)]


jobs_df.tail(5)


jobs_df = jobs_df.dropna(how='all')


jobs_df = jobs_df[jobs_df["job_id"] != "job_id"]


jobs_df["job_id"].nunique()


jobs_df.to_csv("data/jobs.csv",index=False)


jobs_df.shape


skill_lookup=dict(
    zip(skills_df['skill_name'],skills_df['skill_id'])
)


job_skills=[]


for _,row in jobs_df.iterrows():
    job_id=row['job_id']

    required_skills= row['required_skills'].split(',')

    for skill in required_skills:
        skill=skill.strip()

        if skill in skill_lookup:
            job_skills.append([
                job_id,
                skill_lookup[skill],
                "Required"
            ])


for _,row in jobs_df.iterrows():
    job_id=row['job_id']

    preferred_skills= row["preferred_skills"].split(",")
    for skill in preferred_skills:
        skill=skill.strip()

        if skill in skill_lookup:
            job_skills.append([
                job_id,
                skill_lookup[skill],
                "Preferred"
            ])


job_skills_df = pd.DataFrame(
    job_skills,
    columns=[
        "job_id",
        "skill_id",
        "skill_type"
    ]
)


job_skills_df.head()


job_skills_df.shape


job_skills_df.to_csv("data/job_skills.csv",index=False)


job_skills_df.tail()






